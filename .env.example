# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# At least one provider must be configured for the agent to work.
# OpenRouter is recommended — it provides access to 200+ models via a single key.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Model Configuration ─────────────────────────────────────────────────────
# Models used by the complexity router. OpenRouter format: provider/model
DEFAULT_SIMPLE_MODEL=openai/gpt-4o-mini
DEFAULT_COMPLEX_MODEL=openai/gpt-4o-mini

# Complexity thresholds (0.0–1.0). Tasks below simple go to cheap model,
# above complex go to powerful model.
COMPLEXITY_SIMPLE_THRESHOLD=0.3
COMPLEXITY_COMPLEX_THRESHOLD=0.7

# ─── Self-Repair Settings ────────────────────────────────────────────────────
MAX_REPAIR_RETRIES=3

# ─── Database ─────────────────────────────────────────────────────────────────
# Defaults work with docker-compose.dev.yml (Postgres on localhost:5432)
DATABASE_URL=postgresql+asyncpg://codeforge:codeforge@localhost:5432/codeforge
DATABASE_SYNC_URL=postgresql://codeforge:codeforge@localhost:5432/codeforge

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Sandbox (Docker) ────────────────────────────────────────────────────────
SANDBOX_IMAGE=codeforge-sandbox-python:latest
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=512
SANDBOX_CPU_LIMIT=1.0
SANDBOX_NETWORK_DISABLED=true
DOCKER_HOST=unix:///var/run/docker.sock

# ─── Ollama (Local LLM) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── Research / Web Search (Optional) ────────────────────────────────────────
# Enable deep research before coding. Requires Tavily or SerpAPI key.
TAVILY_API_KEY=
SERP_API_KEY=
RESEARCH_ENABLED=true
RESEARCH_MAX_QUERIES=5

# ─── Agent Settings ──────────────────────────────────────────────────────────
AGENT_MODEL=openai/gpt-4o-mini
AGENT_MAX_ITERATIONS=25
AGENT_WORKSPACE_ROOT=/tmp/codeforge-workspace

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
SECRET_KEY=change-me-in-production

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=codeforge-backend
